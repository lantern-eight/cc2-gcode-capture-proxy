# CC2 G-Code Capture Proxy: Configuration
# Copy this file to .env and edit as needed.

# IP address of the Elegoo Centauri Carbon 2 printer
PRINTER_IP=192.168.1.100

# Ports the proxy listens on (host-side mapping done in docker-compose.yml)
HTTP_PORT=80
MQTT_PORT=1883
CAMERA_PORT=8080
MQTT_WS_PORT=9001

# Where captured G-code files are stored (inside the container)
GCODE_DIR=/data/gcode

# Automatically delete G-code files older than this (0 = keep forever)
RETENTION_DAYS=90

# IANA timezone for file timestamps and date directories (default: UTC)
# GCODE_TZ=UTC

# Incomplete upload timeout in seconds
UPLOAD_TIMEOUT=300

# Maximum request body size in bytes (default: 256 MB).
# Raise if your slicer sends single-shot uploads > 256 MB.
# Set to 0 to disable the limit (not recommended).
# MAX_BODY_SIZE=268435456

# Keep full .gcode files alongside JSON metadata (default: false).
# When false, only lightweight JSON metadata is stored; the raw G-code is
# discarded after parsing.  Set to true if you want to archive the original
# files (requires more disk space).
# STORE_GCODE=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
